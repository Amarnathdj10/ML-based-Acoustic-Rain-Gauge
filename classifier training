    "#feature extraction\n",
    "\n",
    "import librosa\n",
    "import soundfile as sf\n",
    "import numpy as np\n",
    "\n",
    "def extract_features(path):\n",
    "    y, sr = sf.read(path)\n",
    "\n",
    "    # Convert stereo to mono if necessary\n",
    "    if y.ndim > 1:\n",
    "        y = np.mean(y, axis=1)\n",
    "\n",
    "    # Ensure float32\n",
    "    y = y.astype(np.float32)\n",
    "\n",
    "    features = {}\n",
    "\n",
    "    # Time-domain features\n",
    "    features[\"zcr\"] = librosa.feature.zero_crossing_rate(y).mean()\n",
    "    features[\"rms\"] = librosa.feature.rms(y=y).mean()\n",
    "\n",
    "    # Spectral features\n",
    "    features[\"centroid\"] = librosa.feature.spectral_centroid(\n",
    "        y=y,\n",
    "        sr=sr\n",
    "    ).mean()\n",
    "\n",
    "    features[\"bandwidth\"] = librosa.feature.spectral_bandwidth(\n",
    "        y=y,\n",
    "        sr=sr\n",
    "    ).mean()\n",
    "\n",
    "    features[\"rolloff\"] = librosa.feature.spectral_rolloff(\n",
    "        y=y,\n",
    "        sr=sr\n",
    "    ).mean()\n",
    "\n",
    "    # MFCCs\n",
    "    mfcc = librosa.feature.mfcc(\n",
    "        y=y,\n",
    "        sr=sr,\n",
    "        n_mfcc=20\n",
    "    )\n",
    "\n",
    "    for i in range(20):\n",
    "        features[f\"mfcc_{i+1}\"] = mfcc[i].mean()\n",
    "        features[f\"mfcc_std_{i+1}\"] = mfcc[i].std()\n",
    "\n",
    "    return features"
   ]
  },
